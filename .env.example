# UCSK Configuration
# Copy to .env and fill in your values

# Gemini API (required for Skill Diffs and AI guidance)
UCSK_GEMINI_API_KEY=

# Qdrant Vector DB
UCSK_QDRANT_HOST=localhost
UCSK_QDRANT_PORT=6333

# Neo4j Graph DB
UCSK_NEO4J_URI=bolt://localhost:7687
UCSK_NEO4J_USER=neo4j
UCSK_NEO4J_PASSWORD=ucsk_secret

# PostgreSQL Event Store
UCSK_POSTGRES_DSN=postgresql+asyncpg://ucsk:ucsk@localhost:5432/ucsk

# Redis
UCSK_REDIS_URL=redis://localhost:6379/0

# Debug mode
UCSK_DEBUG=false
